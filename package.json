{
  "name": "ventas-garzon",
  "version": "1.0.0",
  "description": "Aplicación de comercio electrónico para Ventas Garzón",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client start\"",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client start",
    "build": "npm --prefix client build",
    "server:build": "npm --prefix server build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "npm --prefix server run db:setup"
  },
  "keywords": [
    "ecommerce",
    "ventas-garzon"
  ],
  "author": "Ventas Garzón",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "concurrently": "^7.6.0"
  }
}
